# Copy to .env on the Pi and source before running, or export in systemd/cron.

IOT_API_URL=https://my-hive-production.up.railway.app/api/device-heartbeat
IOT_DEVICE_KEY=pi_test_12345
IOT_DEVICE_ID=pi-001
IOT_DEVICE_NAME=Hive 1 Entrance Node
IOT_REQUEST_TIMEOUT=30

# DS18B20 probe IDs (from: ls /sys/bus/w1/devices/)
IOT_INTERNAL_PROBE_ID=
IOT_EXTERNAL_PROBE_ID=

# Optional BME280 instead of external DS18B20
IOT_USE_BME280_EXTERNAL=false
IOT_BME280_ADDRESS=0x76

# Weight sensor (HX711)
IOT_WEIGHT_ENABLED=false
IOT_HX711_DOUT=5
IOT_HX711_SCK=6

# Bee counter
IOT_BEES_ENABLED=false
IOT_BEE_COUNTS_FILE=/tmp/bee_counts.json
IOT_BEE_WINDOW_SECONDS=300
IOT_BEE_CAMERA_INDEX=0

# YOLO upgrade (Phase 3b) — requires: pip install ultralytics
IOT_BEE_USE_YOLO=false
IOT_BEE_YOLO_MODEL=yolov8n.pt
